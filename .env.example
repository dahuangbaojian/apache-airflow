# Compose
COMPOSE_PROJECT_NAME=airflow-prod
AIRFLOW_IMAGE_NAME=local/airflow:3.1.8
AIRFLOW_VERSION=3.1.8
AIRFLOW_UID=50000
APT_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Airflow metadata database and broker.
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=replace-with-a-strong-password
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_REDIS_PASSWORD=replace-with-a-strong-password

# Airflow security. Generate unique values per environment.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key
SECRET_KEY=replace-with-random-secret-key
JWT_SECRET=replace-with-random-jwt-secret

# Ports and runtime settings.
AIRFLOW_API_PORT=18081
AIRFLOW_FLOWER_PORT=5555
AIRFLOW_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai
AIRFLOW_LOGGING_LEVEL=INFO

# Spark submission defaults from Airflow containers to a host-level Spark master.
SPARK_MASTER_URL=spark://host.docker.internal:7077
AIRFLOW_CONN_SPARK_DEFAULT=spark://host.docker.internal:7077
SPARK_DEPLOY_MODE=client

# Iceberg sample defaults for Spark standalone.
ICEBERG_CATALOG_NAME=iceberg_local
ICEBERG_CATALOG_TYPE=hadoop
ICEBERG_WAREHOUSE=s3://warehouse/iceberg
ICEBERG_NAMESPACE=demo
ICEBERG_TABLE=events

# This endpoint must be reachable from the Spark workers, not only from the Airflow containers.
ICEBERG_S3_ENDPOINT=http://minio.example.com:9000
ICEBERG_S3_ACCESS_KEY_ID=replace-me
ICEBERG_S3_SECRET_ACCESS_KEY=replace-me
ICEBERG_S3_PATH_STYLE_ACCESS=true
